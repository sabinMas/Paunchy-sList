# Backend Configuration
PORT=5000
NODE_ENV=development

# Email Configuration (for submission notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-specific-password
ADMIN_EMAIL=admin@moralkodebat.dev
FROM_EMAIL=noreply@moralkodebat.dev

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Database
DB_PATH=./data/marketplace.db

# Cerebras API Configuration (for AI chatbot feature)
# Get your free API key from: https://console.cerebras.ai
CEREBRAS_API_KEY=your_api_key_here
